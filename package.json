{
  "name": "ehtmlpage",
  "version": "1.0.0",
  "description": "EHTML Web Page",
  "type": "module",
  "scripts": {
    "start": "node main",
    "ehtml:update": "rsync -a --delete ../../my-projects/EHTML/src/ js/ehtml",
    "e-ui:update": "rsync -a --delete ../../my-projects/e-ui/static/js/e-ui/ js/e-ui/ && cp -rf ../../my-projects/e-ui/static/css/e-ui.css css/e-ui.css",
    "nodes:update": "rsync -a --delete ../../my-projects/nodes.js/nodes/ nodes/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Guseyn/EHTML.git"
  },
  "keywords": [
    "HTML",
    "EHTML",
    "cutie",
    "async",
    "tree"
  ],
  "author": "guseyn",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/Guseyn/ehtmlpage/issues"
  },
  "homepage": "https://github.com/Guseyn/ehtmlpage",
  "imports": {
    "#nodes/*": "./nodes/*"
  }
}
